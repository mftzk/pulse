# Copy to .env and adjust. docker-compose reads these.
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=pulse

# Secret used to sign/store sessions. Use a long random string in production.
SESSION_SECRET=please-change-me

# Cloudflare Turnstile (signup bot protection). Leave both empty to disable the
# captcha (useful for local dev). When TURNSTILE_SECRET is set, the API rejects
# signups without a valid token. The site key is public and served to the
# browser via /api/auth/config — no NEXT_PUBLIC build-time var needed.
TURNSTILE_SECRET=
TURNSTILE_SITE_KEY=
